<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Quality Landscape</title>
<script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;background:#0f1117;color:#e2e8f0;font-size:13px}
a{color:inherit;text-decoration:none}
/* layout */
#header{padding:1.2rem 1.5rem .8rem;border-bottom:1px solid #1e2330}
#header h1{font-size:1.3rem;font-weight:700;color:#f8fafc}
#header p{color:#64748b;font-size:.8rem;margin-top:.2rem}
#stats-bar{display:flex;gap:1.5rem;margin-top:.7rem;flex-wrap:wrap}
.stat{display:flex;flex-direction:column}
.stat-val{font-size:1.1rem;font-weight:600;color:#f1f5f9}
.stat-lbl{font-size:.7rem;color:#64748b;text-transform:uppercase;letter-spacing:.05em}
#controls{display:flex;gap:.7rem;align-items:center;padding:.7rem 1.5rem;background:#0f1117;border-bottom:1px solid #1e2330;flex-wrap:wrap}
#controls select,#controls input[type=text]{background:#1e2330;border:1px solid #2d3448;color:#e2e8f0;padding:.3rem .6rem;border-radius:5px;font-size:.8rem}
#controls label{display:flex;align-items:center;gap:.35rem;color:#94a3b8;font-size:.8rem;cursor:pointer}
#main{display:flex;gap:0;border-bottom:1px solid #1e2330}
#scatter-wrap{flex:1 1 0;min-width:0;padding:1rem 1rem .5rem}
#scatter-svg{width:100%;display:block}
#detail{width:280px;flex-shrink:0;border-left:1px solid #1e2330;padding:1rem;overflow-y:auto;max-height:520px}
#detail-placeholder{color:#475569;font-size:.8rem;margin-top:3rem;text-align:center}
/* detail panel */
.d-title{font-size:1rem;font-weight:600;color:#f1f5f9;word-break:break-all}
.d-pkg{font-size:.72rem;color:#64748b;margin:.2rem 0 .6rem}
.risk-badge{display:inline-block;padding:.15rem .55rem;border-radius:4px;font-size:.75rem;font-weight:700;color:#0f1117;margin-bottom:.8rem}
.d-sec{margin-bottom:.9rem}
.d-sec h4{font-size:.7rem;text-transform:uppercase;letter-spacing:.07em;color:#475569;margin-bottom:.4rem;border-bottom:1px solid #1e2330;padding-bottom:.25rem}
.mrow{display:flex;justify-content:space-between;align-items:center;padding:.15rem 0;font-size:.78rem}
.mval{font-weight:600;color:#f1f5f9}
.mval.red{color:#ef4444}.mval.orange{color:#fb923c}.mval.yellow{color:#eab308}.mval.green{color:#22c55e}
.cov-wrap{display:flex;align-items:center;gap:.4rem}
.cov-bar{width:55px;height:6px;background:#1e2330;border-radius:3px;overflow:hidden;flex-shrink:0}
.cov-fill{height:100%;border-radius:3px}
.mini-bar-row{display:flex;align-items:center;gap:.3rem;padding:.1rem 0;font-size:.72rem}
.mini-bar-row span:first-child{width:90px;flex-shrink:0;color:#94a3b8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.mini-bar{flex:1;height:5px;background:#1e2330;border-radius:2px;overflow:hidden}
.mini-bar div{height:100%;background:#3b82f6;border-radius:2px}
.mini-bar-row span:last-child{width:24px;text-align:right;color:#94a3b8}
.sb-hi{color:#ef4444;font-weight:600}
/* table */
#tbl-wrap{padding:.8rem 1.5rem 2rem;overflow-x:auto}
#tbl-wrap h3{font-size:.8rem;color:#475569;text-transform:uppercase;letter-spacing:.07em;margin-bottom:.5rem}
table{width:100%;border-collapse:collapse;font-size:.78rem}
thead th{background:#0f1117;color:#64748b;font-weight:500;text-transform:uppercase;letter-spacing:.05em;font-size:.68rem;padding:.45rem .6rem;border-bottom:1px solid #1e2330;white-space:nowrap;cursor:pointer;user-select:none;position:sticky;top:0}
thead th:hover{color:#94a3b8}
thead th.sorted{color:#60a5fa}
tbody tr{border-bottom:1px solid #161b27;cursor:pointer;transition:background .1s}
tbody tr:hover{background:#161b27}
tbody tr.selected{background:#1a2540}
tbody td{padding:.35rem .6rem;vertical-align:middle}
.cls-name{font-weight:500;color:#f1f5f9;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.pkg-name{color:#475569;max-width:110px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.tbl-cov{display:flex;align-items:center;gap:.35rem}
.tbl-bar{width:40px;height:5px;background:#1e2330;border-radius:2px;overflow:hidden;flex-shrink:0}
.tbl-fill{height:100%;border-radius:2px}
.sb-dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:3px}
.risk-num{font-weight:600}
/* tooltip */
#tooltip{position:fixed;pointer-events:none;background:#1e2330;border:1px solid #3b4261;border-radius:6px;padding:.5rem .7rem;font-size:.75rem;line-height:1.5;max-width:220px;display:none;z-index:100}
#tooltip .tt-name{font-weight:600;color:#f1f5f9;margin-bottom:.2rem;word-break:break-all}
/* code browser */
#code-browser{border-top:1px solid #1e2330;border-bottom:1px solid #1e2330;background:#0d1117}
#cb-header{display:flex;align-items:center;gap:.8rem;padding:.55rem 1.5rem;background:#161b27;border-bottom:1px solid #1e2330;flex-wrap:wrap}
#cb-title{font-weight:600;color:#f1f5f9;font-size:.85rem;flex:1;font-family:'Fira Code',ui-monospace,monospace;word-break:break-all}
.cb-leg{font-size:.68rem;padding:.1rem .4rem;border-radius:3px;flex-shrink:0}
.cb-leg-c{background:rgba(34,197,94,.15);color:#22c55e}
.cb-leg-m{background:rgba(239,68,68,.15);color:#ef4444}
.cb-leg-p{background:rgba(234,179,8,.15);color:#eab308}
#cb-close{background:none;border:1px solid #2d3448;color:#94a3b8;border-radius:4px;padding:.15rem .55rem;cursor:pointer;font-size:.78rem;flex-shrink:0}
#cb-close:hover{background:#1e2330;color:#f1f5f9}
#cb-nav{display:none;align-items:center;gap:.6rem;padding:.4rem 1rem;background:#0f1117;border-bottom:1px solid #1e2330;flex-wrap:wrap}
.cb-nav-btn{background:#1e2330;border:1px solid #2d3448;color:#94a3b8;border-radius:4px;padding:.18rem .7rem;cursor:pointer;font-size:1rem;line-height:1;flex-shrink:0}
.cb-nav-btn:hover:not(:disabled){background:#2d3448;color:#f1f5f9}
.cb-nav-btn:disabled{opacity:.3;cursor:default}
#cb-nav-info{flex:1;display:flex;align-items:center;gap:.5rem;min-width:0;overflow:hidden}
#cb-nav-counter{font-size:.7rem;color:#64748b;flex-shrink:0;white-space:nowrap}
#cb-nav-msg{font-size:.72rem;color:#94a3b8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
#cb-body{overflow:auto;max-height:480px}
#cb-loading{color:#64748b;padding:2rem;text-align:center;font-size:.8rem}
tr.cb-active td{background:rgba(251,191,36,.1) !important}
tr.cb-active .cb-ln{border-right-color:#fbbf24 !important;color:#fbbf24;font-weight:700}
#cb-table{width:100%;border-collapse:collapse;font-family:'Fira Code','Cascadia Code',ui-monospace,monospace;font-size:12px;line-height:1.7}
#cb-table td{padding:0;vertical-align:top}
.cb-ln{width:52px;min-width:52px;text-align:right;padding:0 .5rem;color:#334155;user-select:none;border-right:3px solid transparent;font-size:11px;white-space:nowrap}
.cb-src{padding:0 .8rem 0 .45rem;white-space:pre;color:#e2e8f0}
.cb-ann{padding:0 .5rem 0 0;white-space:nowrap;vertical-align:middle}
tr.cov-C .cb-ln{border-right-color:#22c55e;background:rgba(34,197,94,.07)}
tr.cov-C .cb-src,.cb-ann{background:rgba(34,197,94,.04)}
tr.cov-M .cb-ln{border-right-color:#ef4444;background:rgba(239,68,68,.07)}
tr.cov-M .cb-src{background:rgba(239,68,68,.04)}
tr.cov-M .cb-ann{background:rgba(239,68,68,.04)}
tr.cov-P .cb-ln{border-right-color:#eab308;background:rgba(234,179,8,.07)}
tr.cov-P .cb-src{background:rgba(234,179,8,.04)}
tr.cov-P .cb-ann{background:rgba(234,179,8,.04)}
.ann-badge{display:inline-block;font-size:.62rem;padding:.05rem .32rem;border-radius:3px;margin:.05rem;cursor:default;white-space:nowrap}
.ann-pmd{background:rgba(30,64,175,.3);color:#93c5fd;border:1px solid rgba(30,64,175,.5)}
.ann-cs{background:rgba(22,101,52,.3);color:#86efac;border:1px solid rgba(22,101,52,.5)}
.ann-sb{background:rgba(153,27,27,.3);color:#fca5a5;border:1px solid rgba(153,27,27,.5)}
#ann-tip{position:fixed;pointer-events:none;background:#1e2330;border:1px solid #3b4261;border-radius:6px;padding:.45rem .65rem;font-size:.73rem;line-height:1.5;max-width:320px;display:none;z-index:200;color:#e2e8f0;word-break:break-word}
</style>
</head>
<body>

<div id="header">
  <h1>Quality Landscape — Apache Commons Lang</h1>
  <p>Per-class rollup: JaCoCo coverage · PMD violations · Checkstyle · SpotBugs</p>
  <div id="stats-bar"></div>
</div>

<div id="controls">
  <select id="pkg-filter"><option value="">All packages</option></select>
  <input id="search" type="text" placeholder="Search class…" style="width:160px">
  <label><input type="checkbox" id="hide-inner"> Hide inner classes</label>
  <label><input type="checkbox" id="hide-nocov"> Only classes with coverage data</label>
</div>

<div id="main">
  <div id="scatter-wrap">
    <svg id="scatter-svg"></svg>
  </div>
  <div id="detail">
    <div id="detail-placeholder">← hover or click a class<br><br>
      <span style="font-size:.7rem;color:#334155">Bubble size = total violations<br>Color = risk score<br>Red ring = SpotBugs bugs<br>X = complexity · Y = coverage</span>
    </div>
    <div id="detail-content" style="display:none"></div>
  </div>
</div>

<div id="code-browser" style="display:none">
  <div id="cb-header">
    <span id="cb-title"></span>
    <span class="cb-leg cb-leg-c">■ Covered</span>
    <span class="cb-leg cb-leg-p">■ Partial</span>
    <span class="cb-leg cb-leg-m">■ Missed</span>
    <button id="cb-close" title="Close code browser">✕ close</button>
  </div>
  <div id="cb-nav">
    <button class="cb-nav-btn" id="cb-prev" title="Previous violation">&#8592;</button>
    <div id="cb-nav-info">
      <span id="cb-nav-counter"></span>
      <span id="cb-nav-badge" class="ann-badge"></span>
      <span id="cb-nav-msg"></span>
    </div>
    <button class="cb-nav-btn" id="cb-next" title="Next violation">&#8594;</button>
  </div>
  <div id="cb-body">
    <div id="cb-loading" style="display:none">Loading source…</div>
    <table id="cb-table"></table>
  </div>
</div>

<div id="tbl-wrap">
  <h3>All classes — sorted by risk score <span id="tbl-count"></span></h3>
  <table>
    <thead>
      <tr>
        <th data-col="riskScore" class="sorted">#  Risk ▼</th>
        <th data-col="simpleName">Class</th>
        <th data-col="packageName">Package</th>
        <th data-col="linePct">Line Cov</th>
        <th data-col="branchPct">Branch Cov</th>
        <th data-col="jacocoComplexity">Complexity</th>
        <th data-col="pmdTotal">PMD</th>
        <th data-col="csTotal">CS</th>
        <th data-col="sbTotal">SpotBugs</th>
      </tr>
    </thead>
    <tbody id="tbl-body"></tbody>
  </table>
</div>

<div id="ann-tip"></div>
<div id="tooltip"></div>

<script>
const ALL_DATA = __DATA_JSON__;

// ── colour helpers ───────────────────────────────────────────────────────────
function riskColor(score, max) {
  const t = Math.min(score / (max * 0.7), 1);
  return d3.interpolateRdYlGn(1 - t);
}
function covColor(pct) {
  return pct >= 80 ? '#22c55e' : pct >= 60 ? '#eab308' : pct >= 40 ? '#fb923c' : '#ef4444';
}
function covClass(pct) {
  return pct >= 80 ? 'green' : pct >= 60 ? 'yellow' : pct >= 40 ? 'orange' : 'red';
}

// ── filters & state ──────────────────────────────────────────────────────────
let sortCol = 'riskScore', sortAsc = false;
let selectedClass = null;

function activeData() {
  const pkg       = document.getElementById('pkg-filter').value;
  const q         = document.getElementById('search').value.toLowerCase();
  const hideInner = document.getElementById('hide-inner').checked;
  const hideCov   = document.getElementById('hide-nocov').checked;
  return ALL_DATA.filter(d => {
    if (hideInner && d.isInner) return false;
    if (hideCov && d.jacocoComplexity === 0 && d.linePct === 0) return false;
    if (pkg && d.packageName !== pkg) return false;
    if (q && !d.className.toLowerCase().includes(q) && !d.simpleName.toLowerCase().includes(q)) return false;
    return true;
  }).sort((a, b) => {
    const av = a[sortCol] ?? 0, bv = b[sortCol] ?? 0;
    if (typeof av === 'string') return sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
    return sortAsc ? av - bv : bv - av;
  });
}

// ── summary stats bar ────────────────────────────────────────────────────────
(function buildStats() {
  const withCov = ALL_DATA.filter(d => d.linesCovered + d.linesMissed > 0);
  const avgCov  = withCov.length ? d3.mean(withCov, d => d.linePct).toFixed(1) : '—';
  const sbTotal = d3.sum(ALL_DATA, d => d.sbTotal);
  const pmdTotal= d3.sum(ALL_DATA, d => d.pmdTotal);
  const csTotal = d3.sum(ALL_DATA, d => d.csTotal);
  const stats = [
    ['Classes', ALL_DATA.length],
    ['Avg Line Coverage', avgCov + '%'],
    ['SpotBugs bugs', sbTotal],
    ['PMD violations', pmdTotal.toLocaleString()],
    ['Checkstyle', csTotal.toLocaleString()],
  ];
  const bar = document.getElementById('stats-bar');
  stats.forEach(([lbl, val]) => {
    bar.insertAdjacentHTML('beforeend',
      `<div class="stat"><span class="stat-val">${val}</span><span class="stat-lbl">${lbl}</span></div>`);
  });
})();

// ── package filter options ───────────────────────────────────────────────────
(function buildPkgFilter() {
  const pkgs = [...new Set(ALL_DATA.map(d => d.packageName).filter(Boolean))].sort();
  const sel  = document.getElementById('pkg-filter');
  pkgs.forEach(p => {
    const o = document.createElement('option');
    o.value = p; o.textContent = p.replace('org.apache.commons.lang3', 'o.a.c.lang3');
    sel.appendChild(o);
  });
})();

// ── scatter plot ─────────────────────────────────────────────────────────────
const margin = {top: 28, right: 16, bottom: 52, left: 58};
let plotW, plotH, xScale, yScale, riskMax;

function setupScatter() {
  const svgEl = document.getElementById('scatter-svg');
  const totalW = svgEl.parentElement.clientWidth - 2;
  const totalH = 460;
  svgEl.setAttribute('height', totalH);

  plotW = totalW - margin.left - margin.right;
  plotH = totalH - margin.top  - margin.bottom;

  const svg = d3.select('#scatter-svg').attr('width', totalW);
  svg.selectAll('*').remove();

  const data = activeData();
  if (!data.length) return;

  riskMax = d3.max(data, d => d.riskScore) || 1;

  const xVal = d => Math.max(1, d.jacocoComplexity || d.maxCyclomatic || 1);
  const yVal = d => d.linePct || 0;

  xScale = d3.scaleLog()
    .domain([1, Math.max(10, d3.max(data, xVal))])
    .range([0, plotW]).clamp(true);

  yScale = d3.scaleLinear().domain([0, 100]).range([plotH, 0]);

  const sizeScale = d3.scaleSqrt()
    .domain([0, Math.max(1, d3.max(data, d => d.pmdTotal + d.csTotal + d.sbTotal))])
    .range([3, 18]);

  const g = svg.append('g').attr('transform', `translate(${margin.left},${margin.top})`);

  // quadrant backgrounds
  const xMedian = xScale(d3.median(data, xVal));
  const ySplit  = yScale(70);
  const quads = [
    {x:0,        y:0,      w:xMedian,       h:ySplit,             fill:'rgba(34,197,94,0.05)',   label:'Simple & Covered',   lx:.5, ly:.5},
    {x:xMedian,  y:0,      w:plotW-xMedian, h:ySplit,             fill:'rgba(251,191,36,0.05)',  label:'Complex & Covered',  lx:.5, ly:.5},
    {x:0,        y:ySplit, w:xMedian,       h:plotH-ySplit,       fill:'rgba(148,163,184,0.04)', label:'Simple & Untested',  lx:.5, ly:.5},
    {x:xMedian,  y:ySplit, w:plotW-xMedian, h:plotH-ySplit,       fill:'rgba(239,68,68,0.07)',   label:'⚠ Danger Zone',     lx:.5, ly:.5},
  ];
  quads.forEach(q => {
    g.append('rect').attr('x',q.x).attr('y',q.y).attr('width',q.w).attr('height',q.h).attr('fill',q.fill);
    g.append('text').attr('x', q.x + q.w * q.lx).attr('y', q.y + q.h * q.ly)
      .attr('text-anchor','middle').attr('dominant-baseline','middle')
      .attr('font-size','9').attr('fill','#334155').attr('pointer-events','none')
      .text(q.label);
  });
  // divider lines
  g.append('line').attr('x1',xMedian).attr('x2',xMedian).attr('y1',0).attr('y2',plotH)
    .attr('stroke','#2d3448').attr('stroke-dasharray','3,3');
  g.append('line').attr('x1',0).attr('x2',plotW).attr('y1',ySplit).attr('y2',ySplit)
    .attr('stroke','#2d3448').attr('stroke-dasharray','3,3');

  // axes
  g.append('g').attr('transform',`translate(0,${plotH})`)
    .call(d3.axisBottom(xScale).ticks(5,'~s').tickSize(-plotH))
    .call(ax => { ax.select('.domain').remove(); ax.selectAll('.tick line').attr('stroke','#1e2330'); ax.selectAll('text').attr('fill','#475569').attr('font-size','10'); });
  g.append('g')
    .call(d3.axisLeft(yScale).ticks(5).tickSize(-plotW))
    .call(ax => { ax.select('.domain').remove(); ax.selectAll('.tick line').attr('stroke','#1e2330'); ax.selectAll('text').attr('fill','#475569').attr('font-size','10'); });

  // axis labels
  g.append('text').attr('x', plotW/2).attr('y', plotH+40).attr('text-anchor','middle')
    .attr('fill','#475569').attr('font-size','11').text('Cyclomatic complexity (log scale)');
  g.append('text').attr('transform','rotate(-90)').attr('x',-(plotH/2)).attr('y',-44)
    .attr('text-anchor','middle').attr('fill','#475569').attr('font-size','11').text('Line coverage %');

  // SpotBugs rings (drawn under bubbles)
  g.selectAll('circle.sb-ring').data(data.filter(d => d.sbTotal > 0), d => d.className)
    .join('circle').attr('class','sb-ring')
    .attr('cx', d => xScale(xVal(d))).attr('cy', d => yScale(yVal(d)))
    .attr('r', d => sizeScale(d.pmdTotal + d.csTotal + d.sbTotal) + Math.min(d.sbTotal, 4))
    .attr('fill','none').attr('stroke','#ef4444')
    .attr('stroke-width', d => Math.min(d.sbTotal, 3)).attr('opacity',.6);

  // bubbles
  const tooltip = document.getElementById('tooltip');
  const circles = g.selectAll('circle.cls').data(data, d => d.className)
    .join('circle').attr('class','cls')
    .attr('cx', d => xScale(xVal(d))).attr('cy', d => yScale(yVal(d)))
    .attr('r', d => sizeScale(d.pmdTotal + d.csTotal + d.sbTotal))
    .attr('fill', d => riskColor(d.riskScore, riskMax))
    .attr('fill-opacity',.82)
    .attr('stroke','none').attr('cursor','pointer')
    .on('mousemove', function(event, d) {
      tooltip.style.display = 'block';
      tooltip.style.left = (event.clientX + 14) + 'px';
      tooltip.style.top  = (event.clientY - 10) + 'px';
      tooltip.innerHTML = `<div class="tt-name">${d.simpleName}</div>
        <div style="color:#64748b;font-size:.68rem;margin-bottom:.3rem">${d.packageName}</div>
        Line cov: <b>${d.linePct}%</b> &nbsp; Complexity: <b>${d.jacocoComplexity||d.maxCyclomatic||'—'}</b><br>
        PMD: <b>${d.pmdTotal}</b> &nbsp; CS: <b>${d.csTotal}</b> &nbsp; SpotBugs: <b>${d.sbTotal}</b><br>
        Risk: <b style="color:${riskColor(d.riskScore,riskMax)}">${d.riskScore}</b>`;
      renderDetail(d);
    })
    .on('mouseleave', () => tooltip.style.display = 'none')
    .on('click', (_, d) => selectClass(d));

  highlightSelected();
}

// ── table ────────────────────────────────────────────────────────────────────
function covBarHTML(pct) {
  const p = (pct||0).toFixed(0);
  return `<div class="tbl-cov"><div class="tbl-bar"><div class="tbl-fill" style="width:${p}%;background:${covColor(pct)}"></div></div><span>${p}%</span></div>`;
}

function renderTable() {
  const data = activeData();
  document.getElementById('tbl-count').textContent = `(${data.length})`;
  const tbody = document.getElementById('tbl-body');
  tbody.innerHTML = '';
  data.forEach(d => {
    const tr = document.createElement('tr');
    tr.dataset.cls = d.className;
    if (selectedClass === d.className) tr.classList.add('selected');
    const rm = riskMax || 1;
    const sbHtml = d.sbTotal > 0
      ? `<span class="sb-dot" style="background:${d.sbByPriority?.['1']>0?'#ef4444':'#fb923c'}"></span>${d.sbTotal}`
      : '0';
    tr.innerHTML = `
      <td><span class="risk-num" style="color:${riskColor(d.riskScore,rm)}">${d.riskScore}</span></td>
      <td><span class="cls-name" title="${d.className}">${d.simpleName}</span></td>
      <td><span class="pkg-name" title="${d.packageName}">${d.packageName.replace('org.apache.commons.lang3','o.a.c.l3')}</span></td>
      <td>${covBarHTML(d.linePct)}</td>
      <td>${covBarHTML(d.branchPct)}</td>
      <td>${d.jacocoComplexity || d.maxCyclomatic || '—'}</td>
      <td>${d.pmdTotal}</td>
      <td>${d.csTotal}</td>
      <td>${sbHtml}</td>`;
    tr.addEventListener('click', () => selectClass(d));
    tbody.appendChild(tr);
  });
}

// ── detail panel ─────────────────────────────────────────────────────────────
function metricRowHTML(label, pct, detail) {
  const bar = `<div class="cov-wrap"><div class="cov-bar"><div class="cov-fill" style="width:${pct||0}%;background:${covColor(pct)}"></div></div><span class="mval ${covClass(pct)}">${(pct||0).toFixed(1)}%</span><span style="color:#475569;margin-left:.3rem">${detail}</span></div>`;
  return `<div class="mrow"><span>${label}</span>${bar}</div>`;
}

function renderDetail(d) {
  document.getElementById('detail-placeholder').style.display = 'none';
  const content = document.getElementById('detail-content');
  content.style.display = 'block';
  const rm = riskMax || 1;

  const pmdCats = Object.entries(d.pmdByCategory||{}).sort((a,b)=>b[1]-a[1]);
  const sbCats  = Object.entries(d.sbByCategory||{}).sort((a,b)=>b[1]-a[1]);

  content.innerHTML = `
    <div class="d-title">${d.simpleName}</div>
    <div class="d-pkg">${d.packageName}</div>
    <span class="risk-badge" style="background:${riskColor(d.riskScore,rm)}">Risk ${d.riskScore}</span>

    <div class="d-sec"><h4>Coverage</h4>
      ${metricRowHTML('Lines',   d.linePct,   `${d.linesCovered}/${d.linesCovered+d.linesMissed}`)}
      ${metricRowHTML('Branches',d.branchPct, `${d.branchesCovered}/${d.branchesCovered+d.branchesMissed}`)}
      ${metricRowHTML('Methods', d.methodPct, `${d.methodsCovered}/${d.methodsCovered+d.methodsMissed}`)}
    </div>

    <div class="d-sec"><h4>Complexity</h4>
      <div class="mrow"><span>Total (JaCoCo McCabe)</span><span class="mval">${d.jacocoComplexity||'—'}</span></div>
      ${d.maxCyclomatic ? `<div class="mrow"><span>Max method cyclomatic</span><span class="mval">${d.maxCyclomatic}</span></div>` : ''}
      ${d.maxCognitive  ? `<div class="mrow"><span>Max method cognitive</span><span class="mval">${d.maxCognitive}</span></div>` : ''}
    </div>

    <div class="d-sec"><h4>PMD <span style="color:#3b82f6">${d.pmdTotal}</span></h4>
      ${pmdCats.length ? pmdCats.map(([k,v]) =>
        `<div class="mini-bar-row"><span>${k}</span><div class="mini-bar"><div style="width:${(v/Math.max(1,d.pmdTotal)*100).toFixed(0)}%"></div></div><span>${v}</span></div>`
      ).join('') : '<div style="color:#475569;font-size:.72rem">—</div>'}
    </div>

    <div class="d-sec"><h4>Checkstyle <span style="color:#4ade80">${d.csTotal}</span></h4>
      <div class="mrow"><span>Errors</span><span class="mval red">${d.csErrors||0}</span></div>
      <div class="mrow"><span>Warnings</span><span class="mval yellow">${d.csWarnings||0}</span></div>
    </div>

    <div class="d-sec"><h4>SpotBugs ${d.sbTotal > 0 ? `<span class="sb-hi">${d.sbTotal}</span>` : `<span style="color:#22c55e">0</span>`}</h4>
      ${sbCats.length ? sbCats.map(([k,v]) =>
        `<div class="mrow"><span>${k}</span><span class="mval">${v}</span></div>`
      ).join('') : '<div style="color:#22c55e;font-size:.72rem">No issues found</div>'}
      ${d.sbMinRank < 20 ? `<div class="mrow" style="margin-top:.3rem"><span>Highest severity rank</span><span class="mval red">${d.sbMinRank}</span></div>` : ''}
    </div>`;
}

// ── selection ────────────────────────────────────────────────────────────────
function selectClass(d) {
  selectedClass = d.className;
  highlightSelected();
  renderDetail(d);
  openCodeBrowser(d);
  // highlight the table row but don't scroll the page away from the code browser
  document.querySelectorAll('#tbl-body tr').forEach(tr => {
    tr.classList.toggle('selected', tr.dataset.cls === d.className);
  });
}

// ── code browser ─────────────────────────────────────────────────────────────
function escapeHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function outerCls(cn) {
  return cn.includes('$') ? cn.split('$')[0] : cn;
}

function annToolName(t) {
  return t === 'pmd' ? 'PMD' : t === 'cs' ? 'Checkstyle' : 'SpotBugs';
}

function annCssClass(t) {
  return t === 'pmd' ? 'ann-pmd' : t === 'cs' ? 'ann-cs' : 'ann-sb';
}

function annLabel(a) {
  const prefix = a.t === 'pmd' ? 'PMD' : a.t === 'cs' ? 'CS' : 'SB';
  return `${prefix}: ${(a.r||'').replace(/([a-z])([A-Z])/g,'$1​$2').slice(0,22)}`;
}

let cbCurrentOuter = null;
let cbViolations   = [];
let cbViolIdx      = 0;

// ── violation severity (higher = worse = shown first) ─────────────────────────
function annSeverity(a) {
  if (a.t === 'sb')  return 10000 - (a.rank ?? 20) * 100 - (a.p ?? 3) * 10;
  if (a.t === 'pmd') return  4000 - (a.s  ?? 5)   * 200;
  if (a.t === 'cs')  return a.s === 'error' ? 1000 : 400;
  return 0;
}

function buildViolations(data) {
  const v = [];
  Object.entries(data.ann).forEach(([lineStr, anns]) => {
    const line = parseInt(lineStr, 10);
    anns.forEach(a => v.push({ line, ann: a, score: annSeverity(a) }));
  });
  v.sort((a, b) => b.score - a.score);
  return v;
}

function goToViolation(idx) {
  if (!cbViolations.length) return;
  cbViolIdx = Math.max(0, Math.min(idx, cbViolations.length - 1));
  const v = cbViolations[cbViolIdx];

  document.getElementById('cb-nav-counter').textContent = `${cbViolIdx + 1} / ${cbViolations.length}`;
  const badge = document.getElementById('cb-nav-badge');
  badge.textContent  = annLabel(v.ann);
  badge.className    = `ann-badge ${annCssClass(v.ann.t)}`;
  document.getElementById('cb-nav-msg').textContent = (v.ann.m || '').slice(0, 100);

  document.getElementById('cb-prev').disabled = cbViolIdx === 0;
  document.getElementById('cb-next').disabled = cbViolIdx === cbViolations.length - 1;

  // highlight the active row
  document.querySelectorAll('#cb-table tr.cb-active').forEach(r => r.classList.remove('cb-active'));
  const row = document.querySelector(`#cb-table tr[data-line="${v.line}"]`);
  if (row) { row.classList.add('cb-active'); row.scrollIntoView({block: 'center', behavior: 'smooth'}); }
}

function openCodeBrowser(d) {
  const cb    = document.getElementById('code-browser');
  const outer = outerCls(d.className);
  document.getElementById('cb-title').textContent = outer.replace(/\./g, '/') + '.java';

  if (outer === cbCurrentOuter) {
    cb.style.display = 'block';
    cb.scrollIntoView({behavior: 'smooth', block: 'start'});
    return;
  }
  cbCurrentOuter = outer;
  cbViolations   = [];

  document.getElementById('cb-nav').style.display = 'none';
  const loading = document.getElementById('cb-loading');
  const table   = document.getElementById('cb-table');
  table.innerHTML = '';
  loading.textContent = 'Loading source…';
  loading.style.display = 'block';
  cb.style.display = 'block';
  cb.scrollIntoView({behavior: 'smooth', block: 'start'});

  fetch(`./sources/${encodeURIComponent(outer)}.json`)
    .then(r => { if (!r.ok) throw new Error(`HTTP ${r.status}`); return r.json(); })
    .then(data => {
      loading.style.display = 'none';
      renderCodeTable(data, table);
      cbViolations = buildViolations(data);
      if (cbViolations.length) {
        document.getElementById('cb-nav').style.display = 'flex';
        goToViolation(0);
      }
    })
    .catch(err => {
      loading.textContent = `Source not available (${err.message})`;
    });
}

function renderCodeTable(data, table) {
  const annTip = document.getElementById('ann-tip');
  const frag   = document.createDocumentFragment();

  data.src.forEach((line, i) => {
    const nr   = i + 1;
    const cov  = data.cov[String(nr)];
    const anns = data.ann[String(nr)] || [];

    const tr = document.createElement('tr');
    tr.dataset.line = nr;
    if (cov) tr.className = `cov-${cov}`;

    const tdLn = document.createElement('td');
    tdLn.className = 'cb-ln';
    tdLn.textContent = nr;

    const tdSrc = document.createElement('td');
    tdSrc.className = 'cb-src';
    tdSrc.textContent = line;

    const tdAnn = document.createElement('td');
    tdAnn.className = 'cb-ann';
    anns.forEach(a => {
      const b = document.createElement('span');
      b.className = `ann-badge ${annCssClass(a.t)}`;
      b.textContent = annLabel(a);
      b.addEventListener('mousemove', ev => {
        const sev = a.s !== undefined ? ` · sev ${a.s}` : a.p !== undefined ? ` · pri ${a.p}` : '';
        annTip.innerHTML =
          `<b style="color:#f1f5f9">[${annToolName(a.t)}] ${escapeHtml(a.r||'')}</b>` +
          (sev ? `<br><span style="color:#94a3b8">${escapeHtml(sev)}</span>` : '') +
          `<br>${escapeHtml(a.m||'')}`;
        annTip.style.display = 'block';
        annTip.style.left = (ev.clientX + 14) + 'px';
        annTip.style.top  = (ev.clientY - 10) + 'px';
      });
      b.addEventListener('mouseleave', () => { annTip.style.display = 'none'; });
      // clicking a badge jumps to that violation in the nav
      b.addEventListener('click', () => {
        const vi = cbViolations.findIndex(v => v.line === nr && v.ann === a);
        if (vi >= 0) goToViolation(vi);
      });
      tdAnn.appendChild(b);
    });

    tr.appendChild(tdLn);
    tr.appendChild(tdSrc);
    tr.appendChild(tdAnn);
    frag.appendChild(tr);
  });

  table.appendChild(frag);
}

document.getElementById('cb-prev').addEventListener('click', () => goToViolation(cbViolIdx - 1));
document.getElementById('cb-next').addEventListener('click', () => goToViolation(cbViolIdx + 1));
document.getElementById('cb-close').addEventListener('click', () => {
  document.getElementById('code-browser').style.display = 'none';
});

function highlightSelected() {
  d3.selectAll('circle.cls')
    .attr('stroke', d => d.className === selectedClass ? '#fff' : 'none')
    .attr('stroke-width', d => d.className === selectedClass ? 2 : 0);
  document.querySelectorAll('#tbl-body tr').forEach(tr => {
    tr.classList.toggle('selected', tr.dataset.cls === selectedClass);
  });
}

// ── table sort ───────────────────────────────────────────────────────────────
document.querySelectorAll('thead th[data-col]').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    if (sortCol === col) sortAsc = !sortAsc; else { sortCol = col; sortAsc = false; }
    document.querySelectorAll('thead th').forEach(t => t.classList.remove('sorted'));
    th.classList.add('sorted');
    th.textContent = th.textContent.replace(/[▲▼]/,'') + (sortAsc ? ' ▲' : ' ▼');
    renderTable();
  });
});

// ── filter events ─────────────────────────────────────────────────────────────
['pkg-filter','search','hide-inner','hide-nocov'].forEach(id => {
  document.getElementById(id).addEventListener('change', refresh);
  if (id === 'search') document.getElementById(id).addEventListener('input', refresh);
});

function refresh() { setupScatter(); renderTable(); }

// ── initial render ───────────────────────────────────────────────────────────
setupScatter();
renderTable();
window.addEventListener('resize', () => setupScatter());
</script>
</body>
</html>
